<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net48</TargetFramework>
    <PublishDir>bin\Release\net48\</PublishDir>
    <ModPublisherCommand>NewVersion</ModPublisherCommand>
    
    <!-- 通过这两个参数覆盖默认的 ModId 和公开名称 -->
    <TargetModId>131296</TargetModId>
    <TargetDisplayName>MapExt: Alternate Version(Test)</TargetDisplayName>
  </PropertyGroup>
</Project>
